# App data directory (relative paths below are resolved under this dir)
APP_DATA_DIR=backend/runtime

# SQLite cache + source data paths
SQLITE_CACHE_PATH=cache.db
DATA_DB_PATH=data.db
SQLITE_TIMEOUT_SECONDS=30
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_CACHE_RETRY_ATTEMPTS=4
SQLITE_CACHE_RETRY_DELAY_MS=50
SQLITE_CACHE_SNAPSHOT_RETENTION=3

# Analytics
LOOKBACK_DAYS=504
RISK_RECOMPUTE_INTERVAL_DAYS=7
CROSS_SECTION_MIN_AGE_DAYS=7

# API CORS (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Frontend API proxy target (used by frontend/next.config.js)
BACKEND_API_ORIGIN=http://127.0.0.1:8000

# Production API worker count (keep 1 for current architecture)
BACKEND_WORKERS=1

# Runtime role
# local-ingest runs ingest + deeper refresh lanes; cloud-serve is serving-only.
APP_RUNTIME_ROLE=local-ingest

# Optional: when set, /api/refresh and /api/refresh/status require
# either X-Refresh-Token: <token> or Authorization: Bearer <token>.
REFRESH_API_TOKEN=

# Neon migration and cutover
# Keep DATA_BACKEND=sqlite until parity checks pass and read cutover is approved.
DATA_BACKEND=sqlite
NEON_DATABASE_URL=
NEON_AUTO_SYNC_ENABLED=false
NEON_AUTO_SYNC_REQUIRED=false
NEON_AUTO_SYNC_MODE=incremental
# Comma-separated canonical tables; empty means all canonical tables.
NEON_AUTO_SYNC_TABLES=
NEON_AUTO_PARITY_ENABLED=true
NEON_AUTO_PRUNE_ENABLED=true
# Neon-only retention windows (SQLite remains full history by default).
NEON_SOURCE_RETENTION_YEARS=10
NEON_ANALYTICS_RETENTION_YEARS=5
# Prefer durable serving payload reads locally even before cloud cutover.
SERVING_OUTPUTS_PRIMARY_READS=false
# Controlled read cutover: comma-separated surfaces, or * for all.
# Supported: core_reads,factor_history,price_history,serving_outputs
NEON_READ_SURFACES=
